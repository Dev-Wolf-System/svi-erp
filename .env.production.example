# ============================================================================
# SVI ERP/CRM — Variables de PRODUCCIÓN para docker-compose
# ============================================================================
# Uso:
#   1. cp .env.production.example .env.production
#   2. Completar todos los valores marcados como REQUERIDO
#   3. docker compose --env-file .env.production up -d --build
#
# Notas:
#   - NUNCA commitear .env.production (está en .gitignore)
#   - Las vars NEXT_PUBLIC_* viajan al bundle cliente — no poner secrets ahí
#   - Cualquier var nueva debe declararse también en turbo.json `globalEnv`
#     y, si la consume el contenedor, en docker-compose.yml `environment:`
# ============================================================================


# ╔══════════════════════════════════════════════════════════════════════════╗
# ║ 1. CRÍTICAS — sin esto el deploy no levanta                              ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ─── Supabase self-hosted (ya activo en VPS) ─────────────────────────────────
# REQUERIDO. Copiar las claves del .env del Supabase self-hosted del VPS.
NEXT_PUBLIC_SUPABASE_URL=https://supabase-svi.srv878399.hstgr.cloud
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Hosts públicos ──────────────────────────────────────────────────────────
# REQUERIDO. Hostnames completos, sin protocolo, sin barra final.
#   WEB_HOST   → landing pública + portal cliente/inversor (apps/web)
#   ADMIN_HOST → sistema interno / ERP (apps/admin)
#
# Provisional (subdominios del VPS Hostinger, hasta adquirir dominio propio):
WEB_HOST=svi.srv878399.hstgr.cloud
ADMIN_HOST=svi-erp.srv878399.hstgr.cloud
#
# URLs completas (con https). Las usan el cliente y el server del admin para:
#   - back_urls de Mercado Pago
#   - QR de verificación de contrato (footer del PDF apunta a NEXT_PUBLIC_ADMIN_URL/v/<numero_op>)
NEXT_PUBLIC_APP_URL=https://svi.srv878399.hstgr.cloud
NEXT_PUBLIC_ADMIN_URL=https://svi-erp.srv878399.hstgr.cloud
#
# Cuando se compre el dominio definitivo, cambiar acá y actualizar también:
#   - Supabase Studio → Authentication → URL Configuration (Site URL + Redirect URLs)
#   - DNS del nuevo dominio apuntando al VPS


# ╔══════════════════════════════════════════════════════════════════════════╗
# ║ 2. F4 — Ventas (AFIP + Mercado Pago + Contratos PDF)                     ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ─── AFIP (driver intercambiable) ────────────────────────────────────────────
# Valores: stub | sandbox | production
#   stub        → CAE simulado (dev y operación inicial). Sin certificado.
#   sandbox     → Homologación AFIP. Requiere cert sandbox (NO IMPLEMENTADO TODAVÍA).
#   production  → CAE real (NO IMPLEMENTADO TODAVÍA — pendiente cert AFIP).
# El factory (packages/integrations/src/afip/factory.ts) tira error si se elige
# sandbox o production hasta que esos drivers estén implementados.
AFIP_DRIVER=stub
AFIP_CUIT=
AFIP_PUNTO_VENTA=1
# Path absoluto dentro del contenedor admin (montar via volume cuando se active prod)
AFIP_CERT=
AFIP_KEY=

# ─── Mercado Pago (cobro de señas online) ────────────────────────────────────
# REQUERIDO si se va a usar el botón "Generar link" de la AccionesCard.
# Credenciales productivas: panel MP → Tus integraciones → Credenciales de producción
# Las prod empiezan con APP_USR-, las de test con TEST-.
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
# Secret del webhook MP — Notificaciones → Webhooks. Lo valida HMAC en
# packages/integrations/src/mercadopago/webhook-validator.ts
MP_WEBHOOK_SECRET=

# ─── Storage de contratos firmados ───────────────────────────────────────────
# Antes del primer "Generar contrato" hay que crear el bucket en Studio:
#   Storage → New bucket → Name: contratos-pdf → Public: NO (privado)
# Los PDFs se suben con path versionado: {empresa_id}/{venta_id}/{numero}-vN.pdf
# y se sirven con signed URLs de 1h (createServiceClient en apps/admin/src/lib/supabase/service.ts).
# (No requiere variables adicionales — usa SUPABASE_SERVICE_ROLE_KEY del bloque 1)


# ╔══════════════════════════════════════════════════════════════════════════╗
# ║ 3. Comunicaciones (emails, automatización, WhatsApp)                     ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ─── Resend (emails transaccionales) ─────────────────────────────────────────
# OPCIONAL para F4. Necesario cuando se active el envío de contrato por email,
# recordatorios de pago, etc. Domain debe estar verificado en resend.com.
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@svi.com.ar

# ─── N8N (workflows + automatización) ────────────────────────────────────────
# REQUERIDO en producción si N8N dispara endpoints de SVI (F5.7+).
# El secret se valida en /api/webhooks/n8n/* con header x-n8n-secret.
# Generar: openssl rand -hex 32
# Sincronizar el MISMO valor en la variable SVI_N8N_WEBHOOK_SECRET de N8N.
# Ver docs/n8n/README.md y docs/PRODUCTION_HARDENING.md §15 para rotación.
N8N_WEBHOOK_URL=https://n8n.srv878399.hstgr.cloud/webhook
N8N_WEBHOOK_SECRET=

# ─── Evolution API (WhatsApp Business — base self-hosted) ────────────────────
# Operativa en https://evolution.srv878399.hstgr.cloud (red docker n8n_evoapi).
# Instancia para SVI: SVI-ERP (verificar state=open con curl + QR escaneado
# desde Evolution Manager antes de habilitar el agente IA).
#
# Estas vars las consume el ADMIN cuando el agente IA (F8+) tenga que
# enviar mensajes proactivos directamente. Para F5.7 NO se usan: el workflow
# N8N llama a Evolution con su propia credential (`SVI · Evolution API`).
#
# La apikey global de Evolution (AUTHENTICATION_API_KEY del container) es la
# misma que se carga en la credential N8N. ⚠️ Hoy coincide con POSTGRES_PASSWORD
# del Supabase — rotar y diversificar antes de producción real (HARDENING §15).
EVOLUTION_API_URL=https://evolution.srv878399.hstgr.cloud
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=SVI-ERP


# ╔══════════════════════════════════════════════════════════════════════════╗
# ║ 4. IA y observabilidad                                                   ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ─── Anthropic (Claude — informes IA, recomendaciones) ───────────────────────
# OPCIONAL hasta Fase 8 (IA + analítica). console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=

# ─── Sentry (error tracking) ─────────────────────────────────────────────────
# Recomendado desde día 1. sentry.io → settings → projects → DSN.
# El AUTH_TOKEN solo se usa para subir source maps en el build de CI.
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=svi
SENTRY_PROJECT_WEB=svi-web
SENTRY_PROJECT_ADMIN=svi-admin

# ─── PostHog (analytics + feature flags) ─────────────────────────────────────
# OPCIONAL. eu.posthog.com (cuenta UE) o app.posthog.com (US).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com


# ╔══════════════════════════════════════════════════════════════════════════╗
# ║ 5. Runtime                                                               ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# Forzados por docker-compose pero documentados acá para claridad
NODE_ENV=production
LOG_LEVEL=info                        # 'fatal' | 'error' | 'warn' | 'info' | 'debug'

# Conexión directa a Postgres — solo si hay que correr migrations desde el host
# (drizzle-kit push, psql ad-hoc). En operación normal NO es necesario:
# las apps hablan con Supabase vía API, no SQL directo.
# Formato: postgresql://postgres:CONTRASEÑA-URL-ENCODED@host:5432/postgres
DATABASE_URL=


# ============================================================================
# CHECKLIST PRE-DEPLOY (correr en orden en el VPS)
# ============================================================================
#
# □ Redes externas creadas (ya deberían existir si Traefik está corriendo)
#     docker network ls | grep -E 'n8n_evoapi|supabase_network'
#     # Si falta alguna:
#     docker network create n8n_evoapi
#     docker network create supabase_network
#
# □ Traefik corriendo en n8n_evoapi con resolver `mytlschallenge`
#     docker ps | grep traefik
#
# □ Supabase self-hosted respondiendo en NEXT_PUBLIC_SUPABASE_URL
#     curl -I https://supabase-svi.srv878399.hstgr.cloud
#
# □ Hook JWT activo (Authentication → Hooks → Custom Access Token Hook)
#     Si las queries devuelven 0 filas, el hook NO está activo (ver supabase/SETUP.md §2)
#
# □ Migrations 0001-0020 aplicadas
#     Studio → SQL Editor → ejecutar las que falten desde supabase/migrations/
#     Última: 0020_solicitudes_aporte_y_modo_solicitado.sql (F5.6)
#     Tabla actualizada en supabase/SETUP.md §11
#
# □ N8N — workflow F5.7 importado y operativo
#     Ya creado vía API: id r56M78ub99tNg3EA en https://n8n.srv878399.hstgr.cloud
#     Pendiente solo: mover a /personal/SVI-ERP (UI) + activar toggle.
#     Credentials creadas: SVI · x-n8n-secret + SVI · Evolution API.
#     Sincronizar el N8N_WEBHOOK_SECRET de este .env con la credential N8N.
#     Detalle completo en docs/n8n/README.md.
#
# □ Evolution API — instancia SVI-ERP conectada
#     Hoy state=close. Conectar:
#     1. Login en https://evolution.srv878399.hstgr.cloud (Evolution Manager UI).
#     2. Instancia SVI-ERP → QR Code → escanear con WhatsApp del owner.
#     3. Validar: curl -H "apikey: $EVOLUTION_API_KEY" \
#        $EVOLUTION_API_URL/instance/connectionState/SVI-ERP → state=open
#
# □ Owner / admin con telefono cargado en usuarios
#     El workflow F5.7 (y los próximos F9) consultan usuarios con rol admin/super_admin
#     y telefono != NULL. Verificar:
#     SELECT u.nombre, u.apellido, u.telefono, u.activo, r.nombre AS rol
#     FROM usuarios u
#     JOIN usuario_sucursal_rol usr ON usr.usuario_id = u.id
#     JOIN roles r ON r.id = usr.rol_id
#     WHERE r.nombre IN ('super_admin','admin') AND u.deleted_at IS NULL;
#
# □ Buckets privados creados en Storage:
#     - contratos-pdf       (F4    — contratos de venta)
#     - contratos-fci       (F5.5  — contratos FCI)
#     - recibos-liquidacion (F5.4.1 — recibos de pago a inversores)
#   Todos: Public OFF, file_size_limit 5 MB, allowed_mime_types ['application/pdf']
#   SQL listos para pegar en SETUP.md §11 a §16.
#
# □ Inversores con acceso al portal extranet — sólo si vas a usar /portal/inversor
#     Crear el auth user en Studio → Authentication → Users → Add user (email + password).
#     Vincular en SQL Editor:
#       UPDATE inversores
#       SET portal_user_id = '<UUID_AUTH_USER>', portal_activo = true
#       WHERE id = '<UUID_INVERSOR>';
#
# □ DNS apuntando al VPS
#     A     ${WEB_HOST}      → IP del VPS
#     A     ${ADMIN_HOST}    → IP del VPS
#     (Para los subdominios *.srv878399.hstgr.cloud el DNS ya está en Hostinger)
#     (Traefik obtiene los certs Let's Encrypt automáticamente al primer hit)
#
# □ Redirect URLs configuradas en Supabase
#     Authentication → URL Configuration:
#       Site URL: https://${ADMIN_HOST}
#       Redirect URLs:
#         https://${WEB_HOST}/**
#         https://${ADMIN_HOST}/**
#
# □ Build y up:
#     docker compose --env-file .env.production up -d --build
#     docker compose ps        # svi-web y svi-admin deben estar Up
#     docker compose logs -f   # verificar primeros 30s sin errores
#
# □ Smoke test:
#     curl -I https://${WEB_HOST}            # 200 (landing)
#     curl -I https://${ADMIN_HOST}/login    # 200 (admin)
#
# Para rollback:
#     docker compose down              # baja los servicios SVI (Traefik sigue)
#     docker compose up -d --build     # vuelve a levantar
# ============================================================================
