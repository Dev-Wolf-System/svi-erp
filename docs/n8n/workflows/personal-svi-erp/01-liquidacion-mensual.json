          }
        ],
        [
          {
            "node": "Armar mensaje ERROR",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Split notificar_a": {
      "main": [
        [
          {
            "node": "Armar mensaje OK",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Armar mensaje OK": {
      "main": [
        [
          {
            "node": "Evolution → WA admin (OK)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveExecutionProgress": true,
    "saveDataSuccessExecution": "all",
