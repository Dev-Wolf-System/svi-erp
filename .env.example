# ============================================================================
# SVI ERP/CRM — Variables de entorno
# ============================================================================
# Copiar a .env.local en cada app y completar con valores reales.
# NUNCA commitear .env.local. Mantener este .env.example sincronizado.
# ============================================================================

# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# REQUERIDO en server-side de admin Y web (el portal del inversor lo usa
# desde F5.6). NUNCA exponer al cliente.
# Lo consumen apps/{admin,web}/src/lib/supabase/service.ts
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ===== App URLs =====
NEXT_PUBLIC_APP_URL=http://localhost:3000   # apps/web (landing + portal)
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001 # apps/admin (ERP)

# ===== Mercado Pago =====
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# ===== Resend (emails transaccionales) =====
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@svi.com.ar

# ===== N8N (workflows + automatización) =====
N8N_WEBHOOK_URL=https://n8n.srv878399.hstgr.cloud/webhook
N8N_WEBHOOK_SECRET=

# ===== Anthropic (IA — informes ejecutivos, recomendaciones) =====
ANTHROPIC_API_KEY=

# ===== AFIP (driver intercambiable: stub | sandbox | production) =====
AFIP_DRIVER=stub
AFIP_CUIT=
AFIP_CERT=                                  # path al certificado .crt
AFIP_KEY=                                   # path a la private key .key
AFIP_PUNTO_VENTA=1

# ===== Sentry (observabilidad — desde Fase 2) =====
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=svi
SENTRY_PROJECT_WEB=svi-web
SENTRY_PROJECT_ADMIN=svi-admin

# ===== PostHog (analytics + feature flags) =====
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ===== WhatsApp Business (Evolution API — futuro) =====
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE_ID=

# ===== Logging =====
LOG_LEVEL=info                              # 'fatal' | 'error' | 'warn' | 'info' | 'debug'
NODE_ENV=development
